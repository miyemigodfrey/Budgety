{
  "openapi": "3.0.0",
  "info": {
    "title": "Budgety API",
    "version": "1.0.0",
    "description": "OpenAPI spec for Budgety backend"
  },
  "servers": [
    { "url": "/", "description": "Local server" }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register user",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Register" } } } },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Login" } } } },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/sources": {
      "get": {
        "summary": "List sources",
        "responses": { "200": { "description": "OK" } },
        "security": [{ "bearerAuth": [] }]
      },
      "post": {
        "summary": "Create source",
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SourceCreate" } } } },
        "responses": { "201": { "description": "Created" } },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/sources/{id}": {
      "get": { "summary": "Get source detail", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "OK" } }, "security": [{ "bearerAuth": [] }] },
      "patch": { "summary": "Update source", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "security": [{ "bearerAuth": [] }] },
      "delete": { "summary": "Delete source", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "security": [{ "bearerAuth": [] }] }
    },
    "/api/transactions": {
      "get": { "summary": "List transactions", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "OK" } } },
      "post": { "summary": "Create transaction", "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TransactionCreate" } } } }, "security": [{ "bearerAuth": [] }], "responses": { "201": { "description": "Created" } } }
    },
    "/api/transactions/{id}": {
      "patch": { "summary": "Update transaction", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "security": [{ "bearerAuth": [] }] },
      "delete": { "summary": "Delete transaction", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "security": [{ "bearerAuth": [] }] }
    },
    "/api/dashboard": { "get": { "summary": "Dashboard", "security": [{ "bearerAuth": [] }], "responses": { "200": { "description": "OK" } } } ,
    "/api/export": { "get": { "summary": "Export CSV", "security": [{ "bearerAuth": [] }], "parameters": [{ "name": "start", "in": "query", "schema": { "type": "string", "format": "date" } }, { "name": "end", "in": "query", "schema": { "type": "string", "format": "date" } }], "responses": { "200": { "description": "CSV" } } }
  },
  "components": {
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" } },
    "schemas": {
      "Register": { "type": "object", "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "password": { "type": "string" } }, "required": ["name","email","password"] },
      "Login": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } }, "required": ["email","password"] },
      "SourceCreate": { "type": "object", "properties": { "name": { "type": "string" }, "currency": { "type": "string" }, "balance": { "type": "number" } }, "required": ["name"] },
      "TransactionCreate": { "type": "object", "properties": { "type": { "type": "string", "enum": ["inflow","outflow","transfer"] }, "source": { "type": "string" }, "transferTarget": { "type": "string" }, "amount": { "type": "number" }, "category": { "type": "string" }, "date": { "type": "string", "format": "date-time" }, "description": { "type": "string" } }, "required": ["type","source","amount"] }
    }
  }
}
